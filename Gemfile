source "https://rubygems.org"


# core
gem "middleman", "~> 4.6"
gem "middleman-syntax", "~> 3.6"
gem "middleman-livereload", "~> 3.5"
gem "middleman-autoprefixer", "~> 3.0"
gem "middleman-minify-html", "~> 3.4"
gem "middleman-deploy", "2.0.0.pre.alpha"


# templating Engines
gem "redcarpet"         # markdown parser


# tools
gem "rake", "~> 13.3"   # Task automation


# sass compatibility
gem 'sassc', github: 'sass/sassc-ruby', ref: 'refs/pull/233/head'
gem 'sassc-embedded'    # Compatibility with the latest version of sass dart


gem "builder"           # supports .builder.xml for sitemap
gem "terser", "~> 1.1"  # minify .js files

gem "tzinfo-data", platforms: [:mswin, :mingw, :jruby, :x64_mingw]
gem "wdm", "~> 0.1", platforms: [:mswin, :mingw, :x64_mingw]
gem "net-ftp", "0.2.0"
