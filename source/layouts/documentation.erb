<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8">
        <meta http-equiv="x-ua-compatible" content="ie=edge">
        <meta content="width=device-width, initial-scale=1, shrink-to-fit=no" name="viewport">
        <title><%= current_page.data.title || documentation_title(current_page) %> · Ruby on Rails SaaS Development Framework</title>
        <%= stylesheet_link_tag(lesli_stylesheet_for(current_page)) %>
        <link rel="icon" href="/favicon.png">
    </head>
    <body>
        <%= partial("partials/lesli-aside") %>
        <main>
            <%= partial("partials/lesli-navigation", :locals => { :logo => false }) %>
            <section class="lesli-documentation">
                <%= yield %>
                <%= partial("partials/lesli-footer") %>
            </section>
        </main>
        <%= partial("partials/lesli-icon-engines") %>
        <%= partial("partials/lesli-analytics") %>
        <%= javascript_include_tag "site" %>
        <script>
            document.addEventListener("DOMContentLoaded", () => {
                document.querySelectorAll("pre").forEach((pre) => {
                    const codeBlock = pre.querySelector("code");
                    if (!codeBlock) return;

                    pre.style.cursor = "pointer";
                    pre.title = "Click to copy";

                    pre.addEventListener("click", async () => {
                        try {
                            await navigator.clipboard.writeText(codeBlock.textContent);
                            pre.title = "Copied!";
                            setTimeout(() => {
                                pre.title = "Click to copy";
                            }, 1200);
                        } catch (error) {
                            pre.title = "Copy failed";
                            setTimeout(() => {
                                pre.title = "Click to copy";
                            }, 1200);
                        }
                    });
                });
            });
        </script>
    </body>
</html>
