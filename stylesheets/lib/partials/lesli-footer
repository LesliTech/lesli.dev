:root {
  --aside-width: 450px;
}

@media only screen and (max-width: 768px) {
  :root {
    --aside-width: 0px;
    --lesli-documentation-padding: 2rem 2rem;
  }
}
@media only screen and (min-width: 769px) {
  :root {
    --aside-width: 200px;
    --lesli-documentation-padding: 10px 5rem 2rem;
  }
}
@media only screen and (min-width: 1024px) {
  :root {
    --aside-width: 350px;
  }
}
@media only screen and (min-width: 1216px) {
  :root {
    --aside-width: 450px;
  }
}
footer.lesli-footer {
  background-color: white;
  margin: 4rem auto;
}
footer.lesli-footer .footer-logo {
  display: inline-block;
  width: 100px;
}
footer.lesli-footer .lesli-footer-navigation {
  display: flex;
  border-top: 1px solid #d4d4d4;
  margin-top: 1rem;
}
footer.lesli-footer .lesli-footer-navigation-start,
footer.lesli-footer .lesli-footer-navigation-end {
  display: flex;
  padding: 0;
  align-items: center;
}
footer.lesli-footer .lesli-footer-navigation-start li,
footer.lesli-footer .lesli-footer-navigation-end li {
  list-style: none;
}
footer.lesli-footer .lesli-footer-navigation-start .copy {
  font-size: 1.1rem;
  font-weight: 400;
}
footer.lesli-footer .lesli-footer-navigation-end {
  flex: 1;
  justify-content: end;
}
footer.lesli-footer .lesli-footer-navigation-end li {
  padding: 1.3rem 0.8rem;
}
footer.lesli-footer .lesli-footer-navigation-end svg {
  width: 1.8rem;
  height: 1.8rem;
  fill: rgb(11.375, 71.75, 167.125);
}
