:root {
  --aside-width: 450px;
}

@media only screen and (max-width: 768px) {
  :root {
    --aside-width: 0px;
    --lesli-documentation-padding: 2rem 2rem;
  }
}
@media only screen and (min-width: 769px) {
  :root {
    --aside-width: 200px;
    --lesli-documentation-padding: 10px 5rem 2rem;
  }
}
@media only screen and (min-width: 1024px) {
  :root {
    --aside-width: 350px;
  }
}
@media only screen and (min-width: 1216px) {
  :root {
    --aside-width: 450px;
  }
}
aside.lesli-partial-aside {
  position: fixed;
  width: 90%;
  max-width: 450px;
  max-width: var(--aside-width);
  height: 100%;
  background-color: skyblue;
  background-color: #f5f5f5;
  text-align: right;
}
aside.lesli-partial-aside .lesli-partial-aside-logo {
  display: flex;
  justify-content: end;
  align-items: center;
  margin: 0;
  height: 70px;
  border-bottom: 1px solid #ABB4BD;
}
aside.lesli-partial-aside .lesli-partial-aside-logo img {
  height: calc(70px - 40px);
  margin-right: 2.6rem;
}
aside.lesli-partial-aside nav {
  padding: 2rem 0 10rem;
  overflow: scroll;
  height: 100%;
}
aside.lesli-partial-aside ul {
  margin-bottom: 2rem;
}
aside.lesli-partial-aside ul h3 {
  font-size: 1rem;
  margin: 0 2.6rem 0.4rem;
  color: #34404C;
}
aside.lesli-partial-aside ul h3 a {
  all: unset;
  box-sizing: border-box;
  text-transform: uppercase;
  color: #34404C;
  font-size: 0.9rem;
  font-weight: 700;
}
aside.lesli-partial-aside ul a {
  display: block;
  color: #667383;
  padding: 0.2rem 2.6rem 0.2rem 0;
  text-transform: capitalize;
  font-size: 0.95rem;
  font-size: 1.1rem;
  font-weight: 400;
  transition: all linear 0.2s;
}
aside.lesli-partial-aside ul a:hover {
  cursor: pointer;
  color: #123553;
}

@media only screen and (max-width: 768px) {
  aside.lesli-partial-aside {
    display: none;
  }
  aside.lesli-partial-aside.open {
    display: block;
    z-index: 999;
    width: 100%;
    max-width: initial;
  }
}
