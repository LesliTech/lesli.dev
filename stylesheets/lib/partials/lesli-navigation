:root {
  --aside-width: 450px;
}

@media only screen and (max-width: 768px) {
  :root {
    --aside-width: 0px;
    --lesli-documentation-padding: 2rem 2rem;
  }
}
@media only screen and (min-width: 769px) {
  :root {
    --aside-width: 200px;
    --lesli-documentation-padding: 10px 5rem 2rem;
  }
}
@media only screen and (min-width: 1024px) {
  :root {
    --aside-width: 350px;
  }
}
@media only screen and (min-width: 1216px) {
  :root {
    --aside-width: 450px;
  }
}
nav.lesli-partial-navigation {
  display: flex;
  flex-grow: 0;
  padding: 1rem 1rem;
  justify-content: space-between;
  height: 70px;
}
nav.lesli-partial-navigation ul {
  padding: 0;
  display: flex;
}
nav.lesli-partial-navigation .lesli-partial-navigation-logo a {
  padding: 1rem 0;
  display: block;
}
nav.lesli-partial-navigation .lesli-partial-navigation-logo img {
  height: 30px;
  width: 100%;
}
nav.lesli-partial-navigation a {
  height: 100%;
  display: flex;
  padding: 0 1rem;
  align-items: center;
  font-size: 1.2rem;
  font-weight: 400;
  color: #1a1a1a;
}
nav.lesli-partial-navigation li.lesli-partial-aside-open {
  display: none;
}

@media only screen and (max-width: 768px) {
  nav.lesli-partial-navigation li.lesli-partial-aside-open {
    display: block;
  }
}
