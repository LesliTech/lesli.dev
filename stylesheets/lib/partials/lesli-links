:root {
  --aside-width: 450px;
}

@media only screen and (max-width: 768px) {
  :root {
    --aside-width: 0px;
    --lesli-documentation-padding: 2rem 2rem;
  }
}
@media only screen and (min-width: 769px) {
  :root {
    --aside-width: 200px;
    --lesli-documentation-padding: 10px 5rem 2rem;
  }
}
@media only screen and (min-width: 1024px) {
  :root {
    --aside-width: 350px;
  }
}
@media only screen and (min-width: 1216px) {
  :root {
    --aside-width: 450px;
  }
}
section.lesli-partial-links {
  background-color: #245F93;
  text-align: center;
  padding: 2rem 0;
  display: block;
  width: 100%;
}
section.lesli-partial-links span, section.lesli-partial-links a {
  font-size: 1.6rem;
  color: white;
  padding: 0 1rem;
}

@media only screen and (max-width: 768px) {
  section.lesli-partial-links a {
    display: block;
    font-size: 1.4rem;
  }
}
