.button-primary,
.button-primary-ghost,
.button-primary-outlined {
  border-radius: 6px;
  padding: 0.8rem 1.2rem;
  text-align: center;
  font-weight: 600;
}
.button-primary svg,
.button-primary-ghost svg,
.button-primary-outlined svg {
  max-width: 20px;
  vertical-align: middle;
  margin-bottom: 2px;
}

.button-primary {
  border: none;
  color: #EAEEF2 !important;
  background-color: #245F93;
}

.button-primary-ghost {
  background-color: rgb(205.3573770492, 225.2819672131, 242.8426229508);
  color: rgb(25.9672131148, 68.5245901639, 106.0327868852) !important;
}

.button-primary-outlined {
  box-shadow: inset 0 0 0 2px #245F93;
}
