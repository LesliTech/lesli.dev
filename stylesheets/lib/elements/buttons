.button-primary,
.button-primary-ghost,
.button-primary-outlined {
  border-radius: 6px;
  padding: 0.8rem 1.2rem;
  text-align: center;
  font-weight: 600;
}
.button-primary svg,
.button-primary-ghost svg,
.button-primary-outlined svg {
  max-width: 20px;
  vertical-align: middle;
  margin-bottom: 2px;
}

.button-primary {
  border: none;
  color: #fafafa !important;
  background-color: #0d52bf;
}

.button-primary-ghost {
  background-color: rgb(216.8, 230.6, 252.4);
  color: rgb(9.75, 61.5, 143.25) !important;
}

.button-primary-outlined {
  box-shadow: inset 0 0 0 2px #0d52bf;
}
