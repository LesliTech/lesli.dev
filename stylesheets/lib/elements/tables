table {
  width: 100%;
  border-collapse: collapse;
  border-spacing: 0;
}

table.is-fullwidth {
  width: 100%;
}

table th,
table td {
  padding: 10px;
  text-align: left;
  border: 1px solid #ddd;
}

table th {
  font-weight: bold;
  text-transform: uppercase;
}

@media (max-width: 768px) {
  table {
    font-size: 12px;
  }
  table th, table td {
    padding: 8px;
  }
}
