:root {
  --aside-width: 450px;
}

@media only screen and (max-width: 768px) {
  :root {
    --aside-width: 0px;
    --lesli-documentation-padding: 2rem 2rem;
  }
}
@media only screen and (min-width: 769px) {
  :root {
    --aside-width: 200px;
    --lesli-documentation-padding: 10px 5rem 2rem;
  }
}
@media only screen and (min-width: 1024px) {
  :root {
    --aside-width: 350px;
  }
}
@media only screen and (min-width: 1216px) {
  :root {
    --aside-width: 450px;
  }
}
section.lesli-component-development {
  padding: 8rem 0;
  background-size: 115px 115px;
  background-color: #ffffff;
  background-position: 0 0, 55px 55px;
  background-image: radial-gradient(#8F9BAA 2px, transparent 2px), radial-gradient(#8F9BAA 2px, #ffffff 2px);
}
section.lesli-component-development .columns {
  justify-content: center;
}
section.lesli-component-development .column {
  flex-basis: 400px;
  max-width: 400px;
}
section.lesli-component-development .feature {
  height: 100%;
  padding: 1rem 0 2rem 2rem;
  background-color: white;
  border-radius: 5px;
  border: 1px solid #C7D0DA;
  box-shadow: 0px 2px 18px 0px rgba(141, 174, 201, 0.1);
}
section.lesli-component-development .feature i {
  font-size: 3rem;
  color: #4B5663;
}
section.lesli-component-development .feature h3 {
  margin: 0 0 0.4rem;
  font-weight: 500;
}
section.lesli-component-development .feature p {
  font-size: 1.2rem;
}
