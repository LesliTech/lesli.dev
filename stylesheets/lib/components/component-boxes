:root {
  --aside-width: 450px;
}

@media only screen and (max-width: 768px) {
  :root {
    --aside-width: 0px;
    --lesli-documentation-padding: 2rem 2rem;
  }
}
@media only screen and (min-width: 769px) {
  :root {
    --aside-width: 200px;
    --lesli-documentation-padding: 10px 5rem 2rem;
  }
}
@media only screen and (min-width: 1024px) {
  :root {
    --aside-width: 350px;
  }
}
@media only screen and (min-width: 1216px) {
  :root {
    --aside-width: 450px;
  }
}
.lesli-component-boxes .columns {
  margin: 0 auto;
  display: flex;
  flex-wrap: wrap;
}
.lesli-component-boxes .columns .column {
  flex-grow: 1;
  flex-shrink: 1;
  flex-basis: 0;
  padding: 0.8rem;
}
.lesli-component-boxes .columns .column a {
  min-width: 200px;
  height: 100%;
  display: block;
  padding: 1.8rem 0 2.3rem;
  font-size: 1.2rem;
  text-align: center;
  border-radius: 6px;
  text-decoration: none;
  border: 1px solid silver;
  background-color: white;
}
.lesli-component-boxes .columns .column a svg,
.lesli-component-boxes .columns .column a [class^=ri-] {
  display: block;
  margin: 0 auto;
  font-size: 4.4rem;
  line-height: 1.2;
}
.lesli-component-boxes .columns .column a svg {
  height: 50px;
  fill: rgb(6.9333333333, 25.5666666667, 32.0666666667);
  margin: 0 auto 0.8rem;
}
.lesli-component-boxes .columns .column a .icon-inline {
  font-size: 1.65rem;
}
.lesli-component-boxes .columns .column a h3 {
  font-size: 1.2rem;
  font-weight: 600;
  color: #103b4a;
}
.lesli-component-boxes .columns .column:nth-child(1) a i {
  color: #1F6F8B;
}
.lesli-component-boxes .columns .column:nth-child(2) a i {
  color: #5F6C7D;
}
.lesli-component-boxes .columns .column:nth-child(3) a i {
  color: #C86A2D;
}
.lesli-component-boxes .columns .column:nth-child(4) a i {
  color: #B23A3A;
}
.lesli-component-boxes .columns .column:nth-child(5) a i {
  color: #2D7A68;
}
.lesli-component-boxes .columns .column:nth-child(6) a i {
  color: #A83E6F;
}
.lesli-component-boxes .columns .column:nth-child(7) a i {
  color: #4B5FA8;
}
.lesli-component-boxes .columns .column:nth-child(8) a i {
  color: #B2852D;
}

@media only screen and (max-width: 768px) {
  .lesli-component-boxes .columns {
    margin: 0;
  }
  .lesli-component-boxes .columns .column {
    padding: 1rem 0;
  }
  .lesli-component-boxes .columns .column a {
    padding: 0;
    display: flex;
    font-size: 1.2rem;
    align-items: center;
    border: 0;
    border-bottom: 1px solid silver;
  }
  .lesli-component-boxes .columns .column a [class^=ri-] {
    margin: 0 1rem 0 2.4rem;
    font-size: 2rem;
  }
}
