:root {
  --aside-width: 450px;
}

@media only screen and (max-width: 768px) {
  :root {
    --aside-width: 0px;
    --lesli-documentation-padding: 2rem 2rem;
  }
}
@media only screen and (min-width: 769px) {
  :root {
    --aside-width: 200px;
    --lesli-documentation-padding: 10px 5rem 2rem;
  }
}
@media only screen and (min-width: 1024px) {
  :root {
    --aside-width: 350px;
  }
}
@media only screen and (min-width: 1216px) {
  :root {
    --aside-width: 450px;
  }
}
section.lesli-component-gems {
  padding: 8rem 0 10rem;
}
section.lesli-component-gems .columns {
  display: flex;
  flex-wrap: wrap;
  max-width: 1200px;
  justify-content: center;
  margin: 0 auto;
}
section.lesli-component-gems .column {
  padding: 1rem;
  flex-basis: 300px;
  margin: 0 auto;
  max-width: 320px;
}
section.lesli-component-gems a {
  height: 100%;
  display: block;
  padding: 35px 20px 40px;
  text-align: center;
  border: 1px solid #ABB4BD;
  border-radius: 5px 5px 5px 5px;
  box-shadow: 0px 2px 18px 0px rgba(78, 133, 200, 0.1);
  background-color: #ffffff;
  transition: all linear 0.15s;
}
section.lesli-component-gems a:hover {
  box-shadow: 0px 5px 25px 0px rgba(78, 133, 200, 0.3);
  transform: translateY(-3px);
}
section.lesli-component-gems a svg {
  height: 50px;
  margin: 0 auto 0.8rem;
  fill: rgb(6.9333333333, 25.5666666667, 32.0666666667);
}
section.lesli-component-gems a h3 {
  font-size: 1.2rem;
  font-weight: 600;
  margin: 0 auto 0.2rem;
}
section.lesli-component-gems a p {
  font-size: 1.1rem;
}
