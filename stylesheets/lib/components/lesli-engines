:root {
  --aside-width: 450px;
}

@media only screen and (max-width: 768px) {
  :root {
    --aside-width: 0px;
    --lesli-documentation-padding: 2rem 2rem;
  }
}
@media only screen and (min-width: 769px) {
  :root {
    --aside-width: 200px;
    --lesli-documentation-padding: 10px 5rem 2rem;
  }
}
@media only screen and (min-width: 1024px) {
  :root {
    --aside-width: 350px;
  }
}
@media only screen and (min-width: 1216px) {
  :root {
    --aside-width: 450px;
  }
}
section.lesli-component-engines {
  padding: 8rem 0 10rem;
  background-color: #f9f5f3;
}
section.lesli-component-engines .columns {
  display: flex;
  flex-wrap: wrap;
  max-width: 1200px;
  justify-content: center;
  margin: 0 auto;
}
section.lesli-component-engines .column {
  margin: 0 auto;
  padding: 0.7rem;
  max-width: 300px;
  flex-basis: 300px;
}
section.lesli-component-engines a {
  height: 100%;
  display: block;
  padding: 30px 20px 30px;
  text-align: center;
  border: 1px solid #C7D0DA;
  border-radius: 5px 5px 5px 5px;
  background-color: #ffffff;
  transition: all linear 0.1s;
  box-shadow: rgba(9, 30, 66, 0.1) 0px 4px 8px -2px, rgba(9, 30, 66, 0.02) 0px 0px 0px 1px;
}
section.lesli-component-engines a:hover {
  box-shadow: 0px 5px 20px 0px rgba(78, 133, 200, 0.2);
  transform: translateY(-2px);
}
section.lesli-component-engines a svg {
  height: 60px;
  margin: 0 auto 0.4rem;
  fill: rgb(6.9333333333, 25.5666666667, 32.0666666667);
  fill: #123553;
}
section.lesli-component-engines a h3 {
  font-size: 1.3rem;
  font-weight: 600;
  margin: 0 auto 0.2rem;
}
section.lesli-component-engines a p {
  font-size: 1.2rem;
}
