:root {
  --aside-width: 450px;
}

@media only screen and (max-width: 768px) {
  :root {
    --aside-width: 0px;
    --lesli-documentation-padding: 2rem 2rem;
  }
}
@media only screen and (min-width: 769px) {
  :root {
    --aside-width: 200px;
    --lesli-documentation-padding: 10px 5rem 2rem;
  }
}
@media only screen and (min-width: 1024px) {
  :root {
    --aside-width: 350px;
  }
}
@media only screen and (min-width: 1216px) {
  :root {
    --aside-width: 450px;
  }
}
section.lesli-component-description {
  background-color: #f9f5f3;
  padding: 8rem 0 10rem;
}
section.lesli-component-description .columns {
  margin: 0 auto;
  max-width: 1200px;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-around;
  align-content: space-around;
}
section.lesli-component-description .columns > * {
  flex-basis: 360px;
  max-width: 360px;
}
section.lesli-component-description .column a {
  display: block;
  border-radius: 6px;
  border: 2px solid #000;
  padding: 2rem;
  height: 100%;
  font-weight: 400;
}
section.lesli-component-description .column a i, section.lesli-component-description .column a h3 {
  color: #4B5663;
}
section.lesli-component-description .column a i {
  font-size: 4rem;
}
section.lesli-component-description .column a h3 {
  font-size: 2rem;
  margin: 0 0 0.6rem 0;
}
section.lesli-component-description .column a p {
  font-size: 1.1rem;
  line-height: 1.2;
  margin-bottom: 1rem;
}
section.lesli-component-description .column a ul {
  margin: 0;
  padding-left: 1rem;
}
section.lesli-component-description .column a li {
  list-style: inside;
  list-style-type: "- ";
  font-size: 1.1rem;
  line-height: 1.5;
}

@media only screen and (min-width: 320px) and (max-width: 768px) {
  section.lesli-component-description p.description {
    padding: 0 0.85rem;
    font-size: 1.5rem;
    margin-bottom: 6rem;
  }
  section.lesli-component-description .columns .column {
    margin-bottom: 1rem;
  }
}
