:root {
  --aside-width: 450px;
}

@media only screen and (max-width: 768px) {
  :root {
    --aside-width: 0px;
    --lesli-documentation-padding: 2rem 2rem;
  }
}
@media only screen and (min-width: 769px) {
  :root {
    --aside-width: 200px;
    --lesli-documentation-padding: 10px 5rem 2rem;
  }
}
@media only screen and (min-width: 1024px) {
  :root {
    --aside-width: 350px;
  }
}
@media only screen and (min-width: 1216px) {
  :root {
    --aside-width: 450px;
  }
}
section.lesli-component-demo {
  padding: 6rem 0 6rem;
  background-color: #245F93;
}
section.lesli-component-demo .component-header h2 {
  color: #E3EEF6;
}
section.lesli-component-demo .component-header p {
  display: flex;
  margin: 0 auto;
  max-width: 700px;
  justify-content: space-around;
  color: #E3EEF6;
}
section.lesli-component-demo .component-header p a {
  display: flex;
  align-items: center;
  font-size: 1.3rem;
}
section.lesli-component-demo .component-header p svg {
  width: 25px;
  margin-right: 10px;
  fill: #E3EEF6;
}
section.lesli-component-demo .buttons {
  margin-top: 8rem;
}
