:root {
  --aside-width: 450px;
}

@media only screen and (max-width: 768px) {
  :root {
    --aside-width: 0px;
    --lesli-documentation-padding: 2rem 2rem;
  }
}
@media only screen and (min-width: 769px) {
  :root {
    --aside-width: 200px;
    --lesli-documentation-padding: 10px 5rem 2rem;
  }
}
@media only screen and (min-width: 1024px) {
  :root {
    --aside-width: 350px;
  }
}
@media only screen and (min-width: 1216px) {
  :root {
    --aside-width: 450px;
  }
}
.component-header {
  text-align: center;
  margin-bottom: 4rem;
}
.component-header h2 {
  line-height: 1;
  font-size: 2.6rem;
  margin: 0 auto 1rem;
  color: rgb(91.8, 91.8, 91.8);
}
.component-header p {
  font-size: 2rem;
  line-height: 1.1;
  color: rgb(91.8, 91.8, 91.8);
}

.component-footer {
  text-align: center;
  margin: 6rem 0 2rem;
}
.component-footer p {
  font-size: 2rem;
  line-height: 1.1;
  color: #666666;
}

@media only screen and (min-width: 320px) and (max-width: 768px) {
  .component-header h2 {
    font-size: 1.8rem;
  }
  .component-header p {
    font-size: 1.4rem;
  }
  .component-footer p {
    font-size: 1.4rem;
  }
}
